<Configuration status="WARN">
  <Appenders>
    <Console name="Console" target="SYSTEM_OUT">
      <PatternLayout pattern="%d{HH:mm:ss.SSS} [%t] %-5level %logger{36} - %msg%n"/>
    </Console>
  </Appenders>
  <Loggers>
    <!-- Reduce noise from AWS SDK -->
    <Logger name="com.amazonaws" level="WARN"/>
    <Logger name="software.amazon" level="WARN"/>
    <Logger name="org.apache.http" level="WARN"/>

    <!-- Reduce noise from Iceberg/Parquet -->
    <Logger name="org.apache.iceberg" level="INFO"/>
    <Logger name="org.apache.parquet" level="WARN"/>

    <!-- DuckDB -->
    <Logger name="org.duckdb" level="INFO"/>

    <!-- Our code at INFO level -->
    <Logger name="org.apache.calcite.adapter.govdata" level="INFO"/>
    <Logger name="org.apache.calcite.adapter.file" level="INFO"/>

    <Root level="WARN">
      <AppenderRef ref="Console"/>
    </Root>
  </Loggers>
</Configuration>
