{
  "version": "1.0",
  "defaultSchema": "energy",
  "schemas": [{
    "name": "energy",
    "type": "custom",
    "factory": "org.apache.calcite.adapter.govdata.GovDataSchemaFactory",
    "operand": {
      "dataSource": "energy",
      "directory": "${GOVDATA_PARQUET_DIR}/energy",
      "cacheDirectory": "${GOVDATA_CACHE_DIR}/energy",
      "autoDownload": true,
      "enabledTables": [
        "eia_natural_gas_storage",
        "eia_petroleum_stocks"
      ]
    }
  }]
}
