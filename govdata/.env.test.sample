# Government Data Adapters Test Environment Configuration
# For SEC and Geographic Data Adapters
#
# INSTRUCTIONS:
# 1. Copy this file to .env.test
# 2. Fill in your actual credentials
# 3. Never commit .env.test (it's git-ignored)

# ==========================================
# S3 Configuration (e.g., Cloudflare R2, MinIO, AWS S3)
# ==========================================
AWS_ACCESS_KEY_ID=your-access-key-id-here
AWS_SECRET_ACCESS_KEY=your-secret-access-key-here
AWS_ENDPOINT_OVERRIDE=https://your-s3-endpoint-here.com
AWS_REGION=auto

# ==========================================
# Unified Government Data Directory Configuration - REQUIRED
# ==========================================
# GOVDATA_CACHE_DIR is REQUIRED for all raw data downloads
# GOVDATA_PARQUET_DIR is REQUIRED for all processed parquet files
#
# Directory Structure:
#   Raw data: ${GOVDATA_CACHE_DIR}/{sec,geo,econ}/...
#   Parquet:  ${GOVDATA_PARQUET_DIR}/source={sec,geo,econ}/type={filing,boundary,demographic,employment}/...
#
# Supports local paths or S3 URIs:
#   Local: /Volumes/T9/govdata-parquet
#   S3:    s3://govdata-parquet-v1

GOVDATA_CACHE_DIR=/Volumes/T9/govdata-cache
GOVDATA_PARQUET_DIR=/Volumes/T9/govdata-parquet

# NOTE: Legacy individual cache directories (SEC_DATA_DIRECTORY, GEO_CACHE_DIR, etc.)
# are no longer supported. All adapters now use the unified directory structure above.

# ==========================================
# Unified Date Range Configuration
# ==========================================
# These settings apply to all government data sources
# Each ETL process interprets them appropriately:
#   - SEC: Downloads filings within this range
#   - GEO: Uses GOVDATA_END_YEAR for TIGER/Census data (typically single year)
#   - ECON: Downloads time series data for this range
# Default: Last 5 years of data
GOVDATA_START_YEAR=2010
# GOVDATA_END_YEAR=2024
# CURRENT_YEAR=2026

# ==========================================
# EDGAR Downloader Configuration
# ==========================================
# All these have smart defaults if not specified:

# Company CIKs - supports multiple formats (comma-separated)
# Formats supported:
#   - Raw CIKs: 0000320193,0000789019
#   - Tickers: AAPL,MSFT,GOOGL
#   - Groups: FAANG, MAGNIFICENT7, BIG_TECH, BIG_BANKS, DOW10, FORTUNE10
#   - Mixed: AAPL,0000789019,FAANG
#
# Examples:
# EDGAR_CIKS=AAPL                       # Single company by ticker
# EDGAR_CIKS=0000320193                 # Single company by CIK
# EDGAR_CIKS=FAANG                      # Facebook/Meta, Apple, Amazon, Netflix, Google
# EDGAR_CIKS=MAGNIFICENT7               # Top 7 tech stocks
# EDGAR_CIKS=AAPL,MSFT,GOOGL           # Multiple tickers
# EDGAR_CIKS=DOW10                      # Top 10 Dow Jones companies

# Filing types to download (comma-separated)
# Default: ALL filing types (comprehensive data collection)
# Available filing types:
#   10-K     - Annual report
#   10-Q     - Quarterly report
#   8-K      - Current report (material events)
#   DEF 14A  - Proxy statement
#   20-F     - Annual report for foreign private issuers
#   11-K     - Annual report of employee stock purchase plans
#   S-1      - Registration statement for new securities
#   S-3      - Registration statement for secondary offerings
#   S-4      - Registration for M&A transactions
#   S-8      - Registration for employee benefit plans
#   424B     - Prospectus filed pursuant to Rule 424(b)
#   SC 13G   - Beneficial ownership report
#   SC 13D   - Beneficial ownership report with intent
#   10-K/A   - Amended annual report
#   10-Q/A   - Amended quarterly report
#
# Examples:
# EDGAR_FILING_TYPES=10-K,10-Q                    # Only annual and quarterly
# EDGAR_FILING_TYPES=10-K,10-Q,8-K,DEF 14A       # Core filings only
# (Leave unset for ALL filing types)

# Year range for filings
# Uses unified GOVDATA_START_YEAR and GOVDATA_END_YEAR by default
SEC_START_YEAR=2019
# Can be overridden with EDGAR-specific values if needed:
# EDGAR_START_YEAR=2009
# EDGAR_END_YEAR=2024

# Auto download flag (true/false)
# Default: true
# EDGAR_AUTO_DOWNLOAD=true

# ==========================================
# Test-Specific Overrides
# ==========================================
# These override EDGAR settings for tests only
# TEST_START_YEAR=2020
# TEST_END_YEAR=2023

# ==========================================
# Debug Configuration
# ==========================================
# Enable debug logging
# SEC_DEBUG=true

# ==========================================
# Geographic Data Adapter Configuration
# ==========================================

# Geographic data uses the unified directory structure defined above
# Raw geographic data -> ${GOVDATA_CACHE_DIR}/geo/...
# Parquet geographic data -> ${GOVDATA_PARQUET_DIR}/source=geo/type={boundary,demographic,crosswalk}/...

# Census Bureau API Configuration
# Get your free API key at: https://api.census.gov/data/key_signup.html
# Takes 2 minutes - instant email delivery
CENSUS_API_KEY=your-census-api-key-here

# HUD USER Credentials
# Register at: https://www.huduser.gov/portal/datasets/usps_crosswalk.html
# Takes 5 minutes - credentials work immediately
#
# Option 1: Token-based authentication (preferred)
HUD_TOKEN=your-hud-token-here
# Option 2: Basic authentication
HUD_USERNAME=your-hud-username-here
HUD_PASSWORD=your-hud-password-here

# Geographic data source configuration
# Enabled data sources (comma-separated): tiger, census, hud
GEO_ENABLED_SOURCES=tiger,census,hud

# Data year for TIGER/Census data
# Uses GOVDATA_END_YEAR by default (TIGER data is typically single-year)
# Can be overridden with GEO-specific value if needed:
# GEO_DATA_YEAR=2024

# Auto-download flag (default: true)
GEO_AUTO_DOWNLOAD=true

# Enable geographic debug logging
# GEO_DEBUG=true

# ==========================================
# Economic Data API Keys
# ==========================================
BLS_API_KEY=your-bls-api-key-here
FRED_API_KEY=your-fred-api-key-here
BEA_API_KEY=your-bea-api-key-here

# Public Safety API Keys
# NHTSA_API_KEY=your-nhtsa-api-key-here
# FEMA_API_KEY=your-fema-api-key-here

# Public Data API Keys
# OPENALEX_API_KEY=your-openalex-api-key-here

# Other Settings
ECON_UPDATE_FREQUENCY=daily
# Historical depth uses GOVDATA_START_YEAR to GOVDATA_END_YEAR by default
# Can be overridden with ECON-specific range if needed:
# ECON_START_YEAR=2015
# ECON_END_YEAR=2024

# ==========================================
# Stock Price Data
# ==========================================
ALPHA_VANTAGE_KEY=your-alpha-vantage-key-here
STOOQ_USERNAME=your-stooq-username-here
STOOQ_PASSWORD=your-stooq-password-here
STOCK_PRICE_SOURCE=stooq

# ==========================================
# Execution Engine
# ==========================================
CALCITE_EXECUTION_ENGINE=DUCKDB

# ==========================================
# Pipeline Tracker (S3 backend for parallel coordination)
# ==========================================
CALCITE_TRACKER_BACKEND=s3
CALCITE_TRACKER_S3_BUCKET=s3://your-tracker-bucket-here

# ==========================================
# Vultr GPU Cloud Configuration
# ==========================================
VULTR_API_KEY=your-vultr-api-key-here
VULTR_SSH_KEY_ID=your-vultr-ssh-key-id-here
SSH_KEY_PATH=/root/.ssh/vultr_gpu
VULTR_NVIDIA_SCRIPT_ID=your-nvidia-script-id-here

# ==========================================
# Additional Data Source API Keys
# ==========================================
API_DATA_GOV=your-api-data-gov-key-here
NOAA_CDO_TOKEN=your-noaa-cdo-token-here
EPA_AQS_EMAIL=your-email-here
EPA_AQS_KEY=your-epa-aqs-key-here
OPENFIGI_API_KEY=your-openfigi-api-key-here

# ==========================================
# ETL Tuning
# ==========================================
# Lower to prevent OOM on 8GB machines with large dimension spaces
ETL_MAX_BUFFERED_ROWS=100000
