# ============================================================================
# Government Data Adapters — TEST environment template (.env.test.sample)
# ----------------------------------------------------------------------------
# Copy to .env.test and fill in your credentials. .env.test is GITIGNORED.
# Mirrors the section layout of .env.prod; each credential notes where to get it.
# ============================================================================

# ----------------------------------------------------------------------------
# Object store (Cloudflare R2 / MinIO, S3-compatible)
# R2 keys + account/token: https://dash.cloudflare.com -> R2 -> Manage API Tokens
#                          https://dash.cloudflare.com/profile/api-tokens
# ----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=your-access-key-id-here
AWS_SECRET_ACCESS_KEY=your-secret-access-key-here
AWS_ENDPOINT_OVERRIDE=https://your-s3-endpoint-here.com
AWS_REGION=auto
# Local path or s3:// URI (e.g. s3://govdata-parquet-v1 or /Volumes/T9/govdata-parquet)
GOVDATA_PARQUET_DIR=/Volumes/T9/govdata-parquet
GOVDATA_CACHE_DIR=/Volumes/T9/govdata-cache
GOVDATA_DQ_BUCKET=your-dq-bucket-here
GOVDATA_DQ_TRACKER_BUCKET=your-dq-tracker-bucket-here
CF_ACCOUNT_ID=your-cloudflare-account-id-here
CF_API_TOKEN=your-cloudflare-api-token-here

# ----------------------------------------------------------------------------
# ETL engine + pipeline tracker
# ----------------------------------------------------------------------------
CALCITE_EXECUTION_ENGINE=DUCKDB
DUCKDB_MEMORY_LIMIT=2GB
CALCITE_TRACKER_BACKEND=s3
CALCITE_TRACKER_S3_BUCKET=s3://your-tracker-bucket-here
ETL_LOCAL_RAW_CACHE=/tmp/etl-raw-cache
ETL_FLUSH_THRESHOLD=50000
ETL_MAX_BUFFERED_ROWS=100000
ETL_PARALLEL_THREADS=2
ETL_TRACKER_FLUSH_THRESHOLD=2000

# ----------------------------------------------------------------------------
# Date range (applies to all schemas; GLOBAL-ONLY — no per-schema overrides)
# ----------------------------------------------------------------------------
GOVDATA_START_YEAR=2010
# GOVDATA_END_YEAR=2024     # default: current year
# CURRENT_YEAR=2026

# ----------------------------------------------------------------------------
# SEC + stock prices
# ----------------------------------------------------------------------------
STOCK_PRICE_SOURCE=stooq
# Stooq account (bulk OHLCV): https://stooq.com  (premium login for db/ bulk access)
STOOQ_USERNAME=your-stooq-username-here
STOOQ_PASSWORD=your-stooq-password-here
# Alpha Vantage (free): https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_KEY=your-alpha-vantage-key-here
# Optional EDGAR overrides (unset = smart defaults / ALL):
#   EDGAR_CIKS=AAPL,MSFT | FAANG | MAGNIFICENT7 | 0000320193   (tickers / CIKs / groups)
#   EDGAR_FILING_TYPES=10-K,10-Q,8-K,DEF 14A                   (unset = all types)
#   EDGAR_AUTO_DOWNLOAD=true

# ----------------------------------------------------------------------------
# Geographic (TIGER / Census / HUD)
# ----------------------------------------------------------------------------
GEO_ENABLED_SOURCES=tiger,census,hud
GEO_AUTO_DOWNLOAD=true
# Census (free, instant): https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=your-census-api-key-here
# HUD USER (token preferred; username/password is the fallback):
#   https://www.huduser.gov/portal/dataset/fmr-api.html  (account -> API token)
HUD_TOKEN=your-hud-token-here
HUD_USERNAME=your-hud-username-here
HUD_PASSWORD=your-hud-password-here

# ----------------------------------------------------------------------------
# Economic (BLS / FRED / BEA)
# ----------------------------------------------------------------------------
# BLS (free): https://data.bls.gov/registrationEngine/
BLS_API_KEY=your-bls-api-key-here
# FRED (free): https://fredaccount.stlouisfed.org/apikeys
FRED_API_KEY=your-fred-api-key-here
# BEA (free): https://apps.bea.gov/API/signup/
BEA_API_KEY=your-bea-api-key-here

# ----------------------------------------------------------------------------
# Energy (EIA)
# EIA (free): https://www.eia.gov/opendata/register.php
# ----------------------------------------------------------------------------
ENERGY_EIA_API_KEY=your-eia-api-key-here

# ----------------------------------------------------------------------------
# Weather (NOAA CDO + EPA AQS)
# NOAA_CDO_TOKEN (free): https://www.ncdc.noaa.gov/cdo-web/token
# EPA AQS (free email signup): https://aqs.epa.gov/aqsweb/documents/data_api.html#signup
#   NOTE: legacy — EPA tables now use the public airdata zip bulk files (no auth).
# ----------------------------------------------------------------------------
NOAA_CDO_TOKEN=your-noaa-cdo-token-here
EPA_AQS_EMAIL=your-email-here
EPA_AQS_KEY=your-epa-aqs-key-here

# ----------------------------------------------------------------------------
# Patents (USPTO) · Health (openFDA) · general data.gov · ref/figi
# USPTO Open Data Portal: https://data.uspto.gov/apis  (PatentsView bulk needs no key)
# openFDA (free): https://open.fda.gov/apis/authentication/
# api.data.gov (free, shared gov key): https://api.data.gov/signup/
# OpenFIGI (optional — works unauthenticated): https://www.openfigi.com/api
# ----------------------------------------------------------------------------
USPTO_API_KEY=your-uspto-api-key-here
HEALTH_FDA_API_KEY=your-openfda-api-key-here
API_DATA_GOV=your-api-data-gov-key-here
# OPENFIGI_API_KEY=your-openfigi-api-key-here   # optional (ref/figi schema)

# ----------------------------------------------------------------------------
# Cyber (ThreatFox / OTX / NVD / GitHub)
# ThreatFox / abuse.ch account: https://auth.abuse.ch/  (key at https://threatfox.abuse.ch/api/)
# AlienVault OTX: https://otx.alienvault.com/  (account -> https://otx.alienvault.com/api)
# NVD (free): https://nvd.nist.gov/developers/request-an-api-key
# GitHub PAT: https://github.com/settings/tokens
# ----------------------------------------------------------------------------
CYBER_THREATFOX_API_KEY=your-threatfox-api-key-here
CYBER_OTX_API_KEY=your-otx-api-key-here
CYBER_NVD_API_KEY=your-nvd-api-key-here
CYBER_GITHUB_TOKEN=your-github-token-here

# ----------------------------------------------------------------------------
# Vultr GPU provisioning (embeddings / out-of-band infra)
# Vultr API key: https://my.vultr.com/settings/#settingsapi
# ----------------------------------------------------------------------------
VULTR_API_KEY=your-vultr-api-key-here
VULTR_SSH_KEY_ID=your-vultr-ssh-key-id-here
VULTR_NVIDIA_SCRIPT_ID=your-nvidia-script-id-here
SSH_KEY_PATH=/root/.ssh/vultr_gpu
