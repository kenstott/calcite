# ============================================================================
# DQ environment template (.env.dq.sample)
# ----------------------------------------------------------------------------
# Copy to .env.dq and fill in your credentials. .env.dq is GITIGNORED.
# Source the base prod env first, then this file overrides the DQ-specific vars:
#   source govdata/.env.prod && source govdata/.env.dq
# ============================================================================

# MinIO S3-compatible endpoint
AWS_ACCESS_KEY_ID=your-minio-access-key-here
AWS_SECRET_ACCESS_KEY=your-minio-secret-key-here
AWS_ENDPOINT_OVERRIDE=http://your-minio-host:9002
AWS_REGION=us-east-1

# DQ bucket names on MinIO (same names, different endpoint)
GOVDATA_DQ_BUCKET=govdata-parquet-v1-dq
GOVDATA_DQ_TRACKER_BUCKET=govdata-tracker-v1-dq

# rclone remote name for DQ buckets (separate from prod to avoid accidental prod uploads)
# Must be configured on this machine:
#   rclone config create minio s3 \
#     provider Minio \
#     access_key_id your-minio-access-key-here \
#     secret_access_key your-minio-secret-key-here \
#     endpoint http://your-minio-host:9002 \
#     location_constraint "" \
#     acl private
GOVDATA_DQ_RCLONE_REMOTE=minio

# Disable Cloudflare bucket-reset API (not applicable for MinIO)
CF_ACCOUNT_ID=
CF_API_TOKEN=

# SEC stock-price bulk feed — d_us_txt.zip staged on the local DQ MinIO.
# Enables StooqBulkProxy so stock_prices is populated (was empty: no staged parquet).
BULK_STOCK_PRICE_ZIP=s3://stock-price-bulk/d_us_txt.zip

# ETL in-heap partition-buffer caps — lowered to flush/stream sooner and bound JVM heap
# uniformly across feeds (defaults 200k/50k). Trade-off: more, smaller parquet files,
# coalesced later by Iceberg compaction.
ETL_MAX_BUFFERED_ROWS=50000
ETL_FLUSH_THRESHOLD=20000
